# EmailJS ‚Äî copy to `.env.local`, fill in, restart `npm run dev`.
# https://dashboard.emailjs.com/

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Template ‚Üí your inbox (set ‚ÄúTo email‚Äù to info@whynotjulio.com or {{to_email}})
VITE_EMAILJS_TEMPLATE_NOTIFY=

# Auto-reply ‚Üí visitor: set ‚ÄúTo email‚Äù to {{from_email}} (also {{email}} / {{user_email}} are sent)
VITE_EMAILJS_TEMPLATE_AUTOREPLY=

# 422 ‚Äúrecipients address is empty‚Äù ‚Üí the template‚Äôs ‚ÄúTo email‚Äù is blank or wrong variable name.
